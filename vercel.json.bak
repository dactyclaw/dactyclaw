{
  "rewrites": [
    {
      "source": "/api/tokens",
      "destination": "/api/tokens"
    },
    {
      "source": "/api/top-tokens",
      "destination": "/api/top-tokens"
    },
    {
      "source": "/api/DECTYCLAW-agents",
      "destination": "/api/DECTYCLAW-agents"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}